# ============ APP ============
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# ============ DATABASE ============
DATABASE_URL="postgresql://postgres:password@localhost:5432/xhris_host?schema=public"

# ============ JWT ============
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES=30d

# ============ GOOGLE OAUTH ============
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============ EMAIL (Resend) ============
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============ REDIS (optional) ============
REDIS_URL=redis://localhost:6379

# ============ STORAGE ============
# Cloudflare R2 or AWS S3
STORAGE_ENDPOINT=https://your-account.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_BUCKET=xhris-host
STORAGE_REGION=auto
CDN_URL=https://cdn.xhris.host

# ============ PAYMENTS ============
# Fapshi
FAPSHI_API_KEY=your-fapshi-api-key
FAPSHI_API_USER=your-fapshi-username

# GeniusPay
GENIUSPAY_PUBLIC_KEY=pk_sandbox_xxxxxxxxxxxx
GENIUSPAY_SECRET_KEY=sk_sandbox_xxxxxxxxxxxx
GENIUSPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Google Search Console
GOOGLE_SITE_VERIFICATION=

# MiniPay
MINIPAY_API_KEY=your-minipay-key

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============ LOGS ============
LOG_LEVEL=info

# ============ SECURITY ============
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=200
